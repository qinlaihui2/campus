# ============================================
# 校圈 CampusHub 生产环境配置
# ============================================
# 复制此文件为 .env 并修改配置
#   cp .env.example .env
# ============================================

# --- AI 服务 ---
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# --- MySQL ---
MYSQL_ROOT_PASSWORD=change_me_mysql_root
MYSQL_DATABASE=campus_assistant

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=campus_vector

# --- Redis ---
REDIS_PASSWORD=

# --- RabbitMQ ---
RABBITMQ_USER=admin
RABBITMQ_PASS=change_me_rabbit

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio

# --- JWT ---
JWT_SECRET=change_me_to_a_random_string_at_least_256_bits_long

# --- 服务端口 ---
NGINX_PORT=80
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
APP_PORT=8080
